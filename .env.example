# LLM
AZURE_AI_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_FOUNDRY_API_KEY=

# Memory & storage
MEM0_API_KEY=
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_DB_NAME=agent_research

# MCP server
MCP_SERVER_URL=http://mcp-tool-servers:8010/mcp

# A2A agent card — set to the URL marketplace uses to reach this agent
AGENT_PUBLIC_URL=http://agent-research:8081

# Auth
AUTH_JWT_SECRET=

# Server
PORT=8081
